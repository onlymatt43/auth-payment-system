# =========================
# Local defaults (safe)
# =========================
TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=dev-onlymatt-auth-secret-please-change-in-prod
NEXTAUTH_SECRET=dev-onlymatt-auth-secret-please-change-in-prod

# =========================
# Auth providers (optional in local)
# =========================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =========================
# PayPal (optional in local)
# =========================
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# =========================
# SMTP (optional in local)
# =========================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_AUTH_METHOD=LOGIN
SMTP_USER=
SMTP_PASS=
SMTP_FROM="OnlyPoints <no-reply@example.com>"

# =========================
# Upstash Redis (optional)
# =========================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# =========================
# Feature flags
# =========================
NEXT_PUBLIC_NEW_UI_ENABLED=true
NEXT_PUBLIC_NEW_UI_AUTH=true
NEXT_PUBLIC_NEW_UI_PAYMENT=true
